# ─── MCP Server Mode (HTTP only) ──────────────────────────────────────────────
# Bearer token clients must send when running with `--http`. Required for HTTP
# mode (refuses to start if missing or shorter than 16 chars).
# Generate one with: node -e "console.log(require('crypto').randomUUID())"
MCP_AUTH_TOKEN=

# Port for HTTP mode. Defaults to 3000. Render/Railway/Fly inject this.
PORT=3000

# ─── Instance Type ────────────────────────────────────────────────────────────
# author | publish (default: author). Write tools refuse to run unless 'author'.
AEM_INSTANCE=author

# ─── AEM Connection ───────────────────────────────────────────────────────────
# Author instance URL (required)
AEM_HOST=http://localhost:4502

# Service credentials (use service user or admin for local dev only)
AEM_USERNAME=admin
AEM_PASSWORD=admin

# ─── Platform ─────────────────────────────────────────────────────────────────
# Required. Set to 'aemaacs', 'aem65', or 'aem65lts'
AEM_PLATFORM=aemaacs

# ─── Content Roots ────────────────────────────────────────────────────────────
# Default content root for page queries
AEM_CONTENT_ROOT=/content

# Default DAM root for asset queries
AEM_DAM_ROOT=/content/dam

# ─── Query Safety ─────────────────────────────────────────────────────────────
# Maximum results before a tool forces async execution
AEM_QUERY_ASYNC_THRESHOLD=500

# Max results per QueryBuilder page (never exceed 1000 — AEM hard limit)
AEM_QUERY_PAGE_SIZE=200

# Delay in ms between batches to avoid overloading the instance
AEM_BATCH_DELAY_MS=200

# ─── Jobs ─────────────────────────────────────────────────────────────────────
# How long (in ms) to keep completed job results in memory (default: 1 hour)
AEM_JOB_TTL_MS=3600000

# Poll interval for runtime health checks during long-running async jobs
AEM_JOB_HEALTH_POLL_INTERVAL_MS=15000

# How long a paused job should wait before retrying after health degrades
AEM_JOB_HEALTH_RETRY_AFTER_MS=30000

# Request-latency thresholds for author responsiveness probes
AEM_JOB_HEALTH_DEGRADED_LATENCY_MS=1500
AEM_JOB_HEALTH_CRITICAL_LATENCY_MS=4000

# Runtime pressure thresholds for pausing long-running jobs
AEM_JOB_HEALTH_MAX_HEAP_PERCENT=85
AEM_JOB_HEALTH_MAX_QUEUED_JOBS=100
AEM_JOB_HEALTH_MAX_ACTIVE_JOBS=20
AEM_JOB_HEALTH_MAX_FAILED_JOBS=10

# ─── Logging ──────────────────────────────────────────────────────────────────
# Read-only in-memory job observability for async diagnostics
AEM_JOB_OBSERVABILITY_ENABLED=true
AEM_JOB_OBSERVABILITY_EVENTS_LIMIT=500

# Set to 'true' for verbose debug output
DEBUG=false
DEBUG_VERBOSE=false
